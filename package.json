{
  "name": "@bk.cc/workers-telemetry-client",
  "version": "1.0.0",
  "description": "Lightweight TypeScript client for the Cloudflare Workers Observability Telemetry API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "observability",
    "telemetry",
    "logs",
    "metrics",
    "tracing"
  ],
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "ajv": "^8.18.0",
    "husky": "^9.1.7",
    "msw": "^2.12.10",
    "semantic-release": "^25.0.3",
    "tsup": "^8.4.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
